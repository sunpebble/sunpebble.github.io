---
import ThemeScript from '../components/ThemeScript.astro';
import { STRINGS, HTML_LANG, type Lang } from '../i18n';
import '../styles/site.css';

interface Props {
  title: string;
  description?: string;
  doc?: boolean;
}
const { title, description, doc } = Astro.props;

// Route-level i18n: English lives at the root, Chinese under /zh/. The layout
// derives the locale from the URL so subpages don't have to pass it, and builds
// the counterpart-locale URL for the language toggle + hreflang alternates.
const pathname = Astro.url.pathname;
const isZh = pathname === '/zh' || pathname === '/zh/' || pathname.startsWith('/zh/');
const lang: Lang = isZh ? 'zh' : 'en';
const t = STRINGS[lang];

const homeHref = isZh ? '/zh/' : '/';
const basePath = isZh ? pathname.replace(/^\/zh/, '') || '/' : pathname;
const enHref = basePath;
const zhHref = '/zh' + (basePath === '/' ? '/' : basePath);
const otherHref = isZh ? enHref : zhHref;

const site = Astro.site;
const abs = (p: string) => (site ? new URL(p, site).href : p);

const favicon =
  "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 512 512'%3E%3Crect width='512' height='512' rx='112' fill='%23FFF6E8'/%3E%3Ccircle cx='256' cy='198' r='112' fill='%23F7B733'/%3E%3Cpath fill='%23232733' d='M86 338c0-58 73-98 169-98 102 0 171 39 171 98 0 60-66 98-170 98S86 398 86 338Z'/%3E%3Cpath fill='%23FFF6E8' opacity='.14' d='M139 314c33-27 84-42 142-39 39 2 75 11 103 26-31-29-76-45-129-45-67 0-119 22-116 58Z'/%3E%3Crect x='149' y='339' width='56' height='24' rx='12' fill='%23FFF6E8'/%3E%3Crect x='226' y='339' width='96' height='24' rx='12' fill='%23F7B733'/%3E%3Crect x='343' y='339' width='44' height='24' rx='12' fill='%23FFF6E8' opacity='.82'/%3E%3C/svg%3E";
---
<!doctype html>
<html lang={HTML_LANG[lang]}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta name="theme-color" content="#fff6e8" />
  <ThemeScript />
  <link rel="icon" href={favicon} />
  <link rel="alternate" hreflang="en" href={abs(enHref)} />
  <link rel="alternate" hreflang="zh-Hans" href={abs(zhHref)} />
  <link rel="alternate" hreflang="x-default" href={abs(enHref)} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Albert+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <!-- SVG symbol referenced by the header brand mark -->
  <svg xmlns="http://www.w3.org/2000/svg" style="display:none" aria-hidden="true">
    <symbol id="sunpebble-logo" viewBox="0 0 512 512">
      <rect width="512" height="512" rx="112" fill="#FFF6E8"/>
      <circle cx="256" cy="198" r="112" fill="#F7B733"/>
      <path fill="#232733" d="M86 338c0-58 73-98 169-98 102 0 171 39 171 98 0 60-66 98-170 98S86 398 86 338Z"/>
      <path fill="#FFF6E8" opacity=".14" d="M139 314c33-27 84-42 142-39 39 2 75 11 103 26-31-29-76-45-129-45-67 0-119 22-116 58Z"/>
      <rect x="149" y="339" width="56" height="24" rx="12" fill="#FFF6E8"/>
      <rect x="226" y="339" width="96" height="24" rx="12" fill="#F7B733"/>
      <rect x="343" y="339" width="44" height="24" rx="12" fill="#FFF6E8" opacity=".82"/>
    </symbol>
  </svg>

  <a href="#main-content" class="skip-link">{t.skip}</a>

  <main id="main-content" class="page">
    <header class="header">
      <a href={homeHref} class="header-brand">
        <svg role="img" aria-label="Sunpebble"><use href="#sunpebble-logo"/></svg>
        <span>Sunpebble</span>
      </a>
      <div class="header-tools">
        <nav class="nav" aria-label={lang === 'zh' ? '站点导航' : 'Studio navigation'}>
          <a href={`${homeHref}#apps`}>{t.navApps}</a>
          <a href={`${homeHref}#about`}>{t.navAbout}</a>
        </nav>
        <a class="lang-toggle" href={otherHref} aria-label={t.switchAria} title={t.switchAria}>{t.switchTo}</a>
        <button class="theme-toggle" type="button" aria-label="Toggle dark / light theme" aria-pressed="false" title="Toggle theme">
          <svg class="ico ico-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13.2A8 8 0 1 1 10.8 4a6.2 6.2 0 0 0 9.2 9.2Z"/></svg>
          <svg class="ico ico-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="4.2"/><line x1="12" y1="2.4" x2="12" y2="4.6"/><line x1="12" y1="19.4" x2="12" y2="21.6"/><line x1="2.4" y1="12" x2="4.6" y2="12"/><line x1="19.4" y1="12" x2="21.6" y2="12"/><line x1="5.1" y1="5.1" x2="6.7" y2="6.7"/><line x1="17.3" y1="17.3" x2="18.9" y2="18.9"/><line x1="5.1" y1="18.9" x2="6.7" y2="17.3"/><line x1="17.3" y1="6.7" x2="18.9" y2="5.1"/></svg>
        </button>
      </div>
    </header>

    {doc ? <div class="doc"><slot /></div> : <slot />}
  </main>
</body>
</html>
