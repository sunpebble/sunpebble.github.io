---
import Base from '../layouts/Base.astro';
---
<Base
  title="Sunpebble — Small, polished apps. Pay once."
  description="Sunpebble is a two-person indie studio making small, polished apps. Pay once, no subscription."
>
  <img class="logo" src="/logo.svg" alt="Sunpebble logo" />
  <h1>Sunpebble</h1>
  <p class="tagline">Small, polished apps. Pay once, no subscription.</p>

  <section>
    <h2 class="label">Apps</h2>
    <a class="app" href="/dayroll/">
      <h3>Dayroll</h3>
      <p>The journal you never have to open — one tap, one line a day.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/simmer/">
      <h3>Simmer</h3>
      <p>Kitchen timers that live in your Dynamic Island. Every pot, one glance.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/sleeptab/">
      <h3>Sleeptab</h3>
      <p>Know how much sleep you owe yourself. Sleep debt from Apple Health.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/freshpantry/">
      <h3>Fresh Pantry</h3>
      <p>Your kitchen, remembered. Track what's in the fridge and cook it before it expires.</p>
      <span class="badge">Coming soon</span>
    </a>
  </section>

  <footer>
    A two-person studio — engineering by Kun, design &amp; product by Shuyuan.<br />
    <a href="https://github.com/sunpebble">GitHub</a>
  </footer>
</Base>
