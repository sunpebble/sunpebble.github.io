---
import Base from '../layouts/Base.astro';
---
<Base
  title="Sunpebble — Small, polished apps."
  description="Sunpebble is a two-person indie studio making small, polished apps."
>
  <img class="logo" src="/logo.svg" alt="Sunpebble logo" />
  <h1>Sunpebble</h1>
  <p class="tagline">Small, polished apps.</p>
  <p class="lede">A two-person indie studio — engineering by Kun, design &amp; product by Shuyuan. Every app is a pebble: small, smooth, and made to last.</p>

  <section>
    <h2 class="label">Apps</h2>
    <a class="app" href="/dayroll/">
      <h3>Dayroll</h3>
      <p>The journal you never have to open — one tap, one line a day.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/simmer/">
      <h3>Simmer</h3>
      <p>Kitchen timers that live in your Dynamic Island. Every pot, one glance.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/sleeptab/">
      <h3>Sleeptab</h3>
      <p>Know how much sleep you owe yourself. Sleep debt from Apple Health.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/steady/">
      <h3>Steady</h3>
      <p>Track blood pressure, glucose, meds, and symptoms. Built for doctor visits.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/freshpantry/">
      <h3>Fresh Pantry</h3>
      <p>Your kitchen, remembered. Track what's in the fridge and cook it before it expires.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/cineslate/">
      <h3>Cineslate</h3>
      <p>Browse what's trending, keep what you're watching, and play your own library — privately.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/pathfinding/">
      <h3>Pathfinding</h3>
      <p>Plan a trip in plain language. Chat with an AI planner and see it on the map.</p>
      <span class="badge">Coming soon</span>
    </a>
    <a class="app" href="/quarry/">
      <h3>Quarry</h3>
      <p>Professional database manager for macOS — native, fast, and encrypted-database ready.</p>
      <span class="badge">In development</span>
    </a>
  </section>

  <footer>
    © 2026 Sunpebble · <a href="https://github.com/sunpebble">GitHub</a> · <a href="https://t.me/sunpebble">Telegram</a> · <a href="mailto:support@sunpebblelabs.com">support@sunpebblelabs.com</a>
  </footer>
</Base>

<style>
  .lede { margin-top: 10px; color: var(--pebble); font-size: 1rem; }
</style>
